# Copy this file to .env and adjust values. The .env file is gitignored
# so real secrets never land in version control.

# Grafana admin credentials (required)
GF_SECURITY_ADMIN_PASSWORD=change-me-please

# Host port the Flask app is published on
APP_PORT=5001

# Image name/tag used by docker compose and the deploy/rollback scripts
APP_IMAGE=devops-final-app
APP_TAG=latest
